   "source": [
    "# ── Identify HyP3 file suffixes ───────────────────────────────────────────────\n",
    "# INSAR_GAMMA products contain:\n",
    "#   *_unw_phase.tif  *_corr.tif  *_dem.tif  *_lv_theta.tif  *_lv_phi.tif\n",
    "# INSAR_ISCE_BURST products contain the same naming convention\n",
    "\n",
    "SUFFIX_MAP = {\n",
    "    'unw'   : '_unw_phase.tif',\n",
    "    'corr'  : '_corr.tif',\n",
    "    'dem'   : '_dem.tif',\n",
    "    'theta' : '_lv_theta.tif',\n",
    "    'phi'   : '_lv_phi.tif',\n",
    "    'conncomp': '_conncomp.tif',\n",
    "}\n",
    "\n",
    "def find_file(folder, suffix):\n",
    "    matches = list(Path(folder).glob(f'*{suffix}'))\n",
    "    return matches[0] if matches else None\n",
    "\n",
    "def clip_raster_to_aoi(src_path, dst_path, geoms):\n",
    "    \"\"\"Clip a GeoTIFF to AOI geometry and save to dst_path.\"\"\"\n",
    "    with rasterio.open(src_path) as src:\n",
    "        # Reproject AOI to raster CRS if needed\n",
    "        from shapely.geometry import shape as shp_shape\n",
    "        from pyproj import Transformer\n",
    "        raster_crs = src.crs.to_epsg()\n",
    "        if raster_crs and raster_crs != 4326:\n",
    "            transformer = Transformer.from_crs(4326, raster_crs, always_xy=True)\n",
    "            from shapely.ops import transform as shp_transform\n",
    "            proj_geoms = []\n",
    "            for g in geoms:\n",
    "                s = shp_shape(g)\n",
    "                ps = shp_transform(transformer.transform, s)\n",
    "                proj_geoms.append(mapping(ps))\n",
    "        else:\n",
    "            proj_geoms = geoms\n",
    "        out_img, out_transform = rio_mask(src, proj_geoms, crop=True, nodata=src.nodata)\n",
    "        out_meta = src.meta.copy()\n",
    "        out_meta.update({'height': out_img.shape[1], 'width': out_img.shape[2],\n",
    "                         'transform': out_transform})\n",
    "    with rasterio.open(dst_path, 'w', **out_meta) as dst:\n",
    "        dst.write(out_img)\n",
    "\n",
    "# ── Build clipped data directory ──────────────────────────────────────────────\n",
    "CLIP_DIR = WORK_DIR / 'clipped'\n",
    "CLIP_DIR.mkdir(exist_ok=True)\n",
    "\n",
    "valid_ifgs = []\n",
    "print('Scanning interferogram folders...')\n",
    "for ifg_dir in tqdm(ifg_dirs):\n",
    "    unw = find_file(ifg_dir, SUFFIX_MAP['unw'])\n",
    "    corr = find_file(ifg_dir, SUFFIX_MAP['corr'])\n",
    "    dem  = find_file(ifg_dir, SUFFIX_MAP['dem'])\n",
    "    if unw is None or corr is None:\n",
    "        print(f'  Skipping {ifg_dir.name}: missing unw_phase or corr')\n",
    "        continue\n",
    "    valid_ifgs.append({\n",
    "        'name': ifg_dir.name,\n",
    "        'dir' : ifg_dir,\n",
    "        'unw' : unw, 'corr': corr, 'dem': dem,\n",
    "        'theta': find_file(ifg_dir, SUFFIX_MAP['theta']),\n",
    "        'phi'  : find_file(ifg_dir, SUFFIX_MAP['phi']),\n",
    "        'conncomp': find_file(ifg_dir, SUFFIX_MAP['conncomp']),\n",
    "    })\n",
    "\n",
    "print(f'Valid interferograms: {len(valid_ifgs)}')\n",
    "if len(valid_ifgs) < 3:\n",
    "    raise RuntimeError('Need at least 3 interferograms for SBAS. Check DATA_DIR.')\n",
    "\n",
    "# ── Clip to AOI if provided ────────────────────────────────────────────────────\n",
    "if AOI_GEOMS is not None:\n",
    "    print('Clipping rasters to AOI...')\n",
    "    for ifg in tqdm(valid_ifgs):\n",
    "        dst_dir = CLIP_DIR / ifg['name']\n",
    "        dst_dir.mkdir(exist_ok=True)\n",
    "        for key in ['unw', 'corr', 'dem', 'theta', 'phi', 'conncomp']:\n",
    "            src = ifg[key]\n",
    "            if src is None: continue\n",
    "            dst = dst_dir / src.name\n",
    "            clip_raster_to_aoi(src, dst, AOI_GEOMS)\n",
    "            ifg[key] = dst  # update path to clipped version\n",
    "        ifg['dir'] = dst_dir\n",
    "    print('Clipping done.')\n",
    "\n",
    "# ── Write MintPy config ────────────────────────────────────────────────────────\n",
    "# Use the first valid interferogram folder as the pattern root\n",
    "sample_dir = valid_ifgs[0]['dir']\n",
    "# Determine the common parent of all interferogram dirs\n",
    "ifg_parent = sample_dir.parent\n",
    "\n",
    "ref_lat_str = str(MINTPY_REF_LAT) if MINTPY_REF_LAT else 'auto'\n",
    "ref_lon_str = str(MINTPY_REF_LON) if MINTPY_REF_LON else 'auto'\n",
    "\n",
    "cfg_content = f'''##------------------------ smallbaselineApp.cfg -------------------------##\n",
    "mintpy.load.processor        = hyp3\n",
    "mintpy.load.unwFile          = {ifg_parent}/*/*_unw_phase.tif\n",
    "mintpy.load.corFile          = {ifg_parent}/*/*_corr.tif\n",
    "mintpy.load.connCompFile     = {ifg_parent}/*/*_conncomp.tif\n",
    "mintpy.load.demFile          = {ifg_parent}/*/*_dem.tif\n",
    "mintpy.load.incAngleFile     = {ifg_parent}/*/*_lv_theta.tif\n",
    "mintpy.load.azAngleFile      = {ifg_parent}/*/*_lv_phi.tif\n",
    "mintpy.load.waterMaskFile    = no\n",
    "mintpy.reference.lalo        = {ref_lat_str},{ref_lon_str}\n",
    "mintpy.networkInversion.weightFunc = var\n",
    "mintpy.networkInversion.minNormVelocity = yes\n",
    "mintpy.troposphericDelay.method = {TROPO_METHOD}\n",
    "mintpy.topographicResidual   = yes\n",
    "mintpy.unwrapError.method    = {UNWRAP_ERR}\n",
    "mintpy.geocode               = yes\n",
    "mintpy.save.hdfEos5          = no\n",
    "'''\n",
    "\n",
    "cfg_path = WORK_DIR / 'smallbaselineApp.cfg'\n",
    "cfg_path.write_text(cfg_content)\n",
    "print(f'MintPy config written: {cfg_path}')\n",
    "print(cfg_content)"
   ]
  },
