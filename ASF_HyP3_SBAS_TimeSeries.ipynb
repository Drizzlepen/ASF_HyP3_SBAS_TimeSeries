   "source": [
    "def plot_ts_grid(ts_mm, dates, mask, aoi_gdf=None, max_panels=16,\n",
    "                 vmin=None, vmax=None, save_name='timeseries_grid.png'):\n",
    "    n = min(len(dates), max_panels)\n",
    "    step = max(1, len(dates) // n)\n",
    "    idx  = list(range(0, len(dates), step))[:n]\n",
    "    ncols_g = 4\n",
    "    nrows_g = int(np.ceil(len(idx) / ncols_g))\n",
    "    fig, axes = plt.subplots(nrows_g, ncols_g,\n",
    "                             figsize=(ncols_g * 4, nrows_g * 3.2))\n",
    "    axes = axes.flatten()\n",
    "    vmin = vmin or VLIM_DISP[0]\n",
    "    vmax = vmax or VLIM_DISP[1]\n",
    "    for k, i in enumerate(idx):\n",
    "        d = ts_mm[i].copy().astype(float)\n",
    "        if mask is not None: d[~mask] = np.nan\n",
    "        im = axes[k].imshow(\n",
    "            d, cmap=COLORMAP, vmin=vmin, vmax=vmax,\n",
    "            extent=[LONS.min(), LONS.max(), LATS.min(), LATS.max()],\n",
    "            origin='upper', aspect='auto'\n",
    "        )\n",
    "        if aoi_gdf is not None:\n",
    "            aoi_gdf.boundary.plot(ax=axes[k], color='k', linewidth=0.8)\n",
    "        axes[k].set_title(dates[i], fontsize=8)\n",
    "        axes[k].axis('off')\n",
    "        plt.colorbar(im, ax=axes[k], fraction=0.046, pad=0.04)\n",
    "    for j in range(k + 1, len(axes)):\n",
    "        axes[j].axis('off')\n",
    "    fig.suptitle('LOS Displacement Time-Series (mm, relative to first date)',\n",
    "                 fontsize=12, fontweight='bold', y=1.01)\n",
    "    plt.tight_layout()\n",
    "    out = WORK_DIR / save_name\n",
    "    plt.savefig(out, dpi=DPI, bbox_inches='tight')\n",
    "    print(f'Saved: {out}')\n",
    "    plt.show(); plt.close()\n",
