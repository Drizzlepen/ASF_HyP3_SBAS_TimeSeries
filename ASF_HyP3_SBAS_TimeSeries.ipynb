    "## 15. Temporal Displacement Curves for Selected Points\n",
    "\n",
    "Plots LOS displacement vs. time for each point in `SAMPLE_POINTS`. If `SAMPLE_POINTS` is empty, the 5 pixels with the highest subsidence rate are auto-selected."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 16,
   "id": "61c50a03",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Point (6.4490, 3.4030) is masked (low coherence). Skipping.\n",
      "Point (6.4610, 3.6800) is masked (low coherence). Skipping.\n",
      "Saved: C:\\Users\\USER\\Downloads\\sbas_workspace\\Kiro Job\\temporal_displacement_curves.png\n"
     ]
    }
   ],
   "source": [
    "def latlon_to_rowcol(lat, lon, lats, lons):\n",
    "    row = int(np.argmin(np.abs(lats - lat)))\n",
    "    col = int(np.argmin(np.abs(lons - lon)))\n",
    "    return row, col\n",
    "\n",
    "def parse_dates(date_strs):\n",
    "    fmts = ['%Y%m%d', '%Y-%m-%d']\n",
    "    out = []\n",
    "    for d in date_strs:\n",
    "        for fmt in fmts:\n",
    "            try: out.append(datetime.strptime(d, fmt)); break\n",
    "            except: pass\n",
    "        else: out.append(None)\n",
    "    return out\n",
    "\n",
    "date_objs = parse_dates(ts_dates)\n",
    "\n",
    "# Auto-select top subsidence pixels if no points given\n",
    "if not SAMPLE_POINTS:\n",
    "    print('No SAMPLE_POINTS defined. Auto-selecting top 5 subsidence pixels...')\n",
    "    vel_flat = vel_masked.copy()\n",
    "    vel_flat[~COH_MASK] = np.nan\n",
    "    flat_idx = np.argsort(vel_flat.ravel())\n",
    "    flat_idx = flat_idx[~np.isnan(vel_flat.ravel()[flat_idx])]\n",
    "    top5 = flat_idx[:5]\n",
    "    auto_pts = []\n",
    "    for fi in top5:\n",
    "        r, c = np.unravel_index(fi, vel_flat.shape)\n",
    "        auto_pts.append((float(LATS[r]), float(LONS[c])))\n",
    "    pts_to_plot = auto_pts\n",
    "    print('Auto-selected points (lat, lon):', pts_to_plot)\n",
    "else:\n",
    "    pts_to_plot = SAMPLE_POINTS\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(12, 6))\n",
    "colors = plt.cm.tab10(np.linspace(0, 1, len(pts_to_plot)))\n",
    "\n",
    "for i, (lat, lon) in enumerate(pts_to_plot):\n",
    "    row, col = latlon_to_rowcol(lat, lon, LATS, LONS)\n",
    "    if not COH_MASK[row, col]:\n",
    "        print(f'Point ({lat:.4f}, {lon:.4f}) is masked (low coherence). Skipping.')\n",
    "        continue\n",
    "    ts_pt = ts_data_mm[:, row, col]\n",
    "    # Linear trend\n",
    "    t_days = np.array([(d - date_objs[0]).days for d in date_objs if d])\n",
    "    slope, intercept, r, p, se = linregress(t_days, ts_pt)\n",
    "    trend = slope * t_days + intercept\n",
    "    vel_pt = slope * 365.25\n",
    "    label = f'({lat:.4f}, {lon:.4f})  v={vel_pt:.1f} mm/yr'\n",
    "    ax.plot(date_objs, ts_pt, 'o-', color=colors[i], markersize=4,\n",
    "            linewidth=1.5, label=label)\n",
    "    ax.plot(date_objs, trend, '--', color=colors[i], linewidth=1, alpha=0.7)\n",
    "\n",
    "ax.axhline(0, color='gray', linewidth=0.8, linestyle=':')\n",
    "ax.set_xlabel('Date', fontsize=11)\n",
    "ax.set_ylabel('LOS Displacement (mm)', fontsize=11)\n",
    "ax.set_title('Temporal Displacement Curves (dashed = linear trend)', fontsize=13, fontweight='bold')\n",
    "ax.legend(fontsize=8, loc='best')\n",
    "ax.xaxis.set_major_locator(MaxNLocator(10))\n",
    "plt.xticks(rotation=30, ha='right')\n",
    "plt.tight_layout()\n",
    "out = WORK_DIR / 'temporal_displacement_curves.png'\n",
    "plt.savefig(out, dpi=DPI, bbox_inches='tight')\n",
    "print(f'Saved: {out}')\n",
    "plt.show(); plt.close()"
   ]
  },
