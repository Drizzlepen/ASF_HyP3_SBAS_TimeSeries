    "import sys, os, logging\n",
    "from pathlib import Path\n",
    "\n",
    "# Fix GDAL_DATA before running MintPy\n",
    "if 'GDAL_DATA' not in os.environ:\n",
    "    _py = Path(sys.executable).parent\n",
    "    for _gc in [_py/'Library'/'share'/'gdal', _py.parent/'Library'/'share'/'gdal']:\n",
    "        if _gc.exists():\n",
    "            os.environ['GDAL_DATA'] = str(_gc)\n",
    "            print(f'GDAL_DATA set: {_gc}')\n",
    "            break\n",
    "\n",
    "def run_mintpy(cfg_path, work_dir):\n",
    "    \"\"\"\n",
    "    Run MintPy by calling its Python entry point directly.\n",
    "    This avoids all subprocess PATH issues on Windows.\n",
    "    \"\"\"\n",
    "    # Import MintPy CLI entry point (works for all MintPy versions)\n",
    "    try:\n",
    "        from mintpy.cli.smallbaselineApp import main as sba_main\n",
    "        print('Entry point: mintpy.cli.smallbaselineApp')\n",
    "    except ImportError:\n",
    "        try:\n",
    "            from mintpy.smallbaselineApp import main as sba_main\n",
    "            print('Entry point: mintpy.smallbaselineApp')\n",
    "        except ImportError:\n",
    "            raise ImportError('MintPy not found. Run: conda install -c conda-forge mintpy')\n",
    "\n",
    "    print(f'Config  : {cfg_path}')\n",
    "    print(f'WorkDir : {work_dir}')\n",
    "    print('Starting MintPy SBAS pipeline...\\n')\n",
    "\n",
    "    log_path = Path(work_dir) / 'mintpy_run.log'\n",
    "    log_lines = []\n",
    "\n",
    "    class TeeHandler(logging.StreamHandler):\n",
    "        def emit(self, record):\n",
    "            msg = self.format(record) + '\\n'\n",
    "            print(msg, end='', flush=True)\n",
    "            log_lines.append(msg)\n",
    "\n",
    "    # Attach tee handler to root logger so all MintPy output is captured\n",
    "    root = logging.getLogger()\n",
    "    tee  = TeeHandler()\n",
    "    tee.setLevel(logging.DEBUG)\n",
    "    orig_handlers = root.handlers[:]\n",
    "    orig_level    = root.level\n",
    "    root.handlers = [tee]\n",
    "    root.setLevel(logging.DEBUG)\n",
    "\n",
    "    # ── Smart resume: detect completed steps and skip them ────────────────────\n",
    "    _orig_argv = sys.argv[:]\n",
    "    _wdir = Path(work_dir)\n",
    "    # If timeseries.h5 already exists, skip straight to velocity\n",
    "    # If velocity.h5 already exists too, skip to geocode\n",
    "    _has_ts  = (_wdir / 'timeseries.h5').exists()\n",
    "    _has_vel = (_wdir / 'velocity.h5').exists()\n",
    "    if _has_vel:\n",
    "        _start = 'geocode'\n",
    "        print('velocity.h5 found - resuming from geocode step.')\n",
    "    elif _has_ts:\n",
    "        _start = 'velocity'\n",
    "        print('timeseries.h5 found - resuming from velocity step.')\n",
    "    else:\n",
    "        _start = None\n",
    "        print('No prior outputs found - running full pipeline.')\n",
    "    # Also fix inputs/smallbaselineApp.cfg to prevent bridging/pyaps errors\n",
    "    _icfg = _wdir / 'inputs' / 'smallbaselineApp.cfg'\n",
    "    if _icfg.exists():\n",
    "        _txt = _icfg.read_text(encoding='utf-8')\n",
    "        import re as _re\n",
    "        _txt = _re.sub(r'(mintpy\\.unwrapError\\.method\\s*=\\s*)\\S+', r'\\g<1>no', _txt)\n",
    "        _txt = _re.sub(r'(mintpy\\.troposphericDelay\\.method\\s*=\\s*)\\S+', r'\\g<1>no', _txt)\n",
    "        _txt = _re.sub(r'(mintpy\\.reference\\.lalo\\s*=\\s*)auto,auto', r'\\g<1>auto', _txt)\n",
    "        _icfg.write_text(_txt, encoding='utf-8')\n",
    "    if _start:\n",
    "        sys.argv = ['smallbaselineApp.py', str(cfg_path), '--dir', str(work_dir), '--start', _start]\n",
    "    else:\n",
    "        sys.argv = ['smallbaselineApp.py', str(cfg_path), '--dir', str(work_dir)]\n",
    "    print('Command:', ' '.join(sys.argv))\n",
    "\n",
    "    try:\n",
    "        sba_main()\n",
    "        print('\\nMintPy completed successfully.')\n",
    "    except SystemExit as e:\n",
    "        if e.code not in (0, None):\n",
    "            raise RuntimeError(f'MintPy exited with code {e.code}. Check log: {log_path}')\n",
    "        print('\\nMintPy completed successfully.')\n",
    "    finally:\n",
    "        sys.argv         = _orig_argv\n",
    "        root.handlers    = orig_handlers\n",
    "        root.setLevel(orig_level)\n",
    "        log_path.write_text(''.join(log_lines))\n",
    "        print(f'Log saved: {log_path}')\n",
    "\n",
    "run_mintpy(cfg_path, WORK_DIR)"
   ]
  },
