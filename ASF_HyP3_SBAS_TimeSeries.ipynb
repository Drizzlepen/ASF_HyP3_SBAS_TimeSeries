  {
   "cell_type": "code",
   "execution_count": 19,
   "id": "04e653b8",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Saved: C:\\Users\\USER\\Downloads\\sbas_workspace\\Kiro Job\\network_baseline.png\n"
     ]
    }
   ],
   "source": [
    "# Parse date pairs from interferogram folder names\n",
    "# HyP3 naming: S1AA_20200101T000000_20200113T000000_...\n",
    "import re\n",
    "\n",
    "def extract_dates_from_name(name):\n",
    "    matches = re.findall(r'(\\d{8})T\\d{6}', name)\n",
    "    if len(matches) >= 2:\n",
    "        return matches[0], matches[1]\n",
    "    # fallback: any 8-digit date\n",
    "    matches = re.findall(r'(\\d{8})', name)\n",
    "    if len(matches) >= 2:\n",
    "        return matches[0], matches[1]\n",
    "    return None, None\n",
    "\n",
    "pairs = []\n",
    "for ifg in valid_ifgs:\n",
    "    d1, d2 = extract_dates_from_name(ifg['name'])\n",
    "    if d1 and d2:\n",
    "        pairs.append((d1, d2))\n",
    "\n",
    "if pairs:\n",
    "    all_dates = sorted(set(d for p in pairs for d in p))\n",
    "    date_idx  = {d: i for i, d in enumerate(all_dates)}\n",
    "    fig, ax = plt.subplots(figsize=(12, 5))\n",
    "    for d1, d2 in pairs:\n",
    "        x1, x2 = date_idx[d1], date_idx[d2]\n",
    "        ax.plot([x1, x2], [0, 0], 'b-', linewidth=1, alpha=0.5)\n",
    "        ax.plot([x1, x2], [0, 0], 'ko', markersize=4)\n",
    "    ax.set_xticks(range(len(all_dates)))\n",
    "    ax.set_xticklabels(all_dates, rotation=45, ha='right', fontsize=7)\n",
    "    ax.set_yticks([])\n",
    "    ax.set_title(f'SBAS Interferogram Network ({len(pairs)} pairs)', fontsize=12, fontweight='bold')\n",
    "    ax.set_xlabel('Acquisition Date')\n",
    "    plt.tight_layout()\n",
    "    out = WORK_DIR / 'network_baseline.png'\n",
    "    plt.savefig(out, dpi=DPI, bbox_inches='tight')\n",
    "    print(f'Saved: {out}')\n",
    "    plt.show(); plt.close()\n",
    "else:\n",
    "    print('Could not parse date pairs from folder names.')"
   ]
  },
