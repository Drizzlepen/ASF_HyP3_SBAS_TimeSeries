   "source": [
    "## 4. Data Acquisition\n",
    "\n",
    "Handles all three data source modes. Downloads and unzips HyP3 interferogram products."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "4ca46e8e",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "No zip files found; assuming data is already unzipped.\n",
      "Found 24 interferogram folder(s).\n",
      "Sample: S1AA_20150521T180129_20150602T180130_VVP012_INT80_G_ueF_740B\n"
     ]
    }
   ],
   "source": [
    "# ── Ensure core imports are available regardless of cell run order ────────────\n",
    "import os, sys, zipfile, shutil\n",
    "from pathlib import Path\n",
    "try:\n",
    "    from tqdm.notebook import tqdm as _tqdm\n",
    "except ImportError:\n",
    "    def _tqdm(it, **kw): return it  # plain fallback\n",
    "\n",
    "# ── Helper: unzip all .zip files in DATA_DIR ──────────────────────────────────\n",
    "def unzip_hyp3_products(data_dir):\n",
    "    zips = list(Path(data_dir).glob('*.zip'))\n",
    "    if not zips:\n",
    "        print('No zip files found; assuming data is already unzipped.')\n",
    "        return\n",
    "    print(f'Unzipping {len(zips)} archive(s)...')\n",
    "    for z in _tqdm(zips):\n",
    "        with zipfile.ZipFile(z, 'r') as zf:\n",
    "            zf.extractall(data_dir)\n",
    "    print('Unzip complete.')\n",
    "\n",
    "# ── Mode: SDK ─────────────────────────────────────────────────────────────────\n",
    "def acquire_via_sdk():\n",
    "    import hyp3_sdk as sdk\n",
    "    print('Connecting to ASF HyP3...')\n",
    "    hyp3 = sdk.HyP3(username=ASF_USERNAME, password=ASF_PASSWORD)\n",
    "    kwargs = {'job_type': HYP3_JOB_TYPE}\n",
    "    if HYP3_PROJECT_NAME:\n",
    "        kwargs['name'] = HYP3_PROJECT_NAME\n",
    "    batch = hyp3.find_jobs(**kwargs)\n",
    "    jobs  = [j for j in batch if j.complete()]\n",
    "    jobs  = jobs[:HYP3_MAX_JOBS]\n",
    "    print(f'Found {len(jobs)} completed {HYP3_JOB_TYPE} jobs.')\n",
    "    if not jobs:\n",
    "        raise RuntimeError('No completed jobs found. Check project name / job type.')\n",
    "    print(f'Downloading to {DATA_DIR} ...')\n",
    "    for job in _tqdm(jobs):\n",
    "        job.download_files(location=DATA_DIR)\n",
    "    unzip_hyp3_products(DATA_DIR)\n",
    "\n",
    "# ── Mode: Script ──────────────────────────────────────────────────────────────\n",
    "def acquire_via_script():\n",
    "    script = Path(ASF_DOWNLOAD_SCRIPT)\n",
    "    if not script.exists():\n",
    "        raise FileNotFoundError(f'Download script not found: {script}')\n",
    "    print(f'Reading download script: {script}')\n",
    "    # Inject credentials into environment so the script can use them\n",
    "    env = os.environ.copy()\n",
    "    env['ASF_USERNAME'] = ASF_USERNAME\n",
    "    env['ASF_PASSWORD'] = ASF_PASSWORD\n",
    "    # Run the script with DATA_DIR as working directory\n",
    "    result = subprocess.run(\n",
    "        [sys.executable, str(script)],\n",
    "        cwd=str(DATA_DIR), env=env, capture_output=True, text=True\n",
    "    )\n",
    "    print(result.stdout[-3000:] if result.stdout else '')\n",
    "    if result.returncode != 0:\n",
    "        print('STDERR:', result.stderr[-2000:])\n",
    "        raise RuntimeError('Download script failed. See output above.')\n",
    "    unzip_hyp3_products(DATA_DIR)\n",
    "\n",
    "# ── Mode: Local ───────────────────────────────────────────────────────────────\n",
    "def acquire_local():\n",
    "    unzip_hyp3_products(DATA_DIR)\n",
    "\n",
    "# ── Dispatch ──────────────────────────────────────────────────────────────────\n",
    "if DATA_SOURCE == 'sdk':\n",
    "    acquire_via_sdk()\n",
    "elif DATA_SOURCE == 'script':\n",
    "    acquire_via_script()\n",
    "elif DATA_SOURCE == 'local':\n",
    "    acquire_local()\n",
    "else:\n",
    "    raise ValueError(f'Unknown DATA_SOURCE: {DATA_SOURCE}')\n",
    "\n",
    "# Discover interferogram folders\n",
    "ifg_dirs = sorted([d for d in DATA_DIR.iterdir() if d.is_dir()])\n",
    "print(f'Found {len(ifg_dirs)} interferogram folder(s).')\n",
    "if ifg_dirs:\n",
    "    print('Sample:', ifg_dirs[0].name)"
   ]
  },
