    "def plot_map(data, title, cbar_label, vmin, vmax, cmap=COLORMAP,\n",
    "             mask=None, aoi_gdf=None, save_name=None, figsize=(10, 7)):\n",
    "    \"\"\"Generic map plotter with colorbar, AOI overlay, and optional save.\"\"\"\n",
    "    disp = data.copy().astype(float)\n",
