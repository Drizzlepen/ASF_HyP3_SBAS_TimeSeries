   "source": [
    "## 5. AOI Geometry Masking\n",
    "\n",
    "Loads your shapefile or KMZ and reprojects to WGS84. The AOI geometry is used to clip all rasters before MintPy loading."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "9ca90011",
   "metadata": {
    "scrolled": true
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "AOI loaded: 1 feature(s), CRS=EPSG:4326\n"
     ]
    },
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 600x500 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "def load_aoi(aoi_file):\n",
    "    \"\"\"Load AOI from .shp or .kmz and return a GeoDataFrame in EPSG:4326.\"\"\"\n",
    "    aoi_path = Path(aoi_file)\n",
    "    if not aoi_path.exists():\n",
    "        raise FileNotFoundError(f'AOI file not found: {aoi_path}')\n",
    "\n",
    "    if aoi_path.suffix.lower() == '.kmz':\n",
    "        # KMZ is a zipped KML\n",
    "        import zipfile as _zf\n",
    "        kml_dir = WORK_DIR / 'aoi_kml'\n",
    "        kml_dir.mkdir(exist_ok=True)\n",
    "        with _zf.ZipFile(aoi_path, 'r') as z:\n",
    "            z.extractall(kml_dir)\n",
    "        kml_files = list(kml_dir.rglob('*.kml'))\n",
    "        if not kml_files:\n",
    "            raise RuntimeError('No KML found inside KMZ.')\n",
    "        import fiona\n",
    "        fiona.drvsupport.supported_drivers['KML'] = 'rw'\n",
    "        fiona.drvsupport.supported_drivers['LIBKML'] = 'rw'\n",
    "        gdf = gpd.read_file(str(kml_files[0]), driver='KML')\n",
    "    else:\n",
    "        gdf = gpd.read_file(str(aoi_path))\n",
    "\n",
    "    gdf = gdf.to_crs('EPSG:4326')\n",
    "    gdf = gdf[gdf.geometry.notnull()]\n",
    "    print(f'AOI loaded: {len(gdf)} feature(s), CRS={gdf.crs}')\n",
    "    return gdf\n",
    "\n",
    "def get_aoi_geom(gdf):\n",
    "    \"\"\"Return merged geometry as a list of GeoJSON-like dicts.\"\"\"\n",
    "    merged = unary_union(gdf.geometry)\n",
    "    return [mapping(merged)]\n",
    "\n",
    "AOI_GDF   = None\n",
    "AOI_GEOMS = None\n",
    "if AOI_FILE is not None:\n",
    "    AOI_GDF   = load_aoi(AOI_FILE)\n",
    "    AOI_GEOMS = get_aoi_geom(AOI_GDF)\n",
    "    # Quick preview\n",
    "    fig, ax = plt.subplots(figsize=(6, 5))\n",
    "    AOI_GDF.plot(ax=ax, facecolor='none', edgecolor='red', linewidth=2)\n",
    "    ax.set_title('Area of Interest (AOI)')\n",
    "    ax.set_xlabel('Longitude'); ax.set_ylabel('Latitude')\n",
    "    plt.tight_layout(); plt.savefig(WORK_DIR / 'aoi_preview.png', dpi=DPI)\n",
    "    plt.show()\n",
    "else:\n",
    "    print('No AOI file specified. Processing full scene extent.')"
   ]
  },
