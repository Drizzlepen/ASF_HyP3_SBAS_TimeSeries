    "def find_h5(work_dir, pattern):\n",
    "    matches = sorted(Path(work_dir).glob(pattern))\n",
    "    if not matches:\n",
    "        raise FileNotFoundError(f'No file matching {pattern} in {work_dir}')\n",
    "    return matches[0]\n",
    "\n",
    "# ── Load time-series (prefer timeseries_demErr.h5 > timeseries.h5) ────────────\n",
    "for _pat in ['timeseries_demErr.h5', 'timeseries.h5']:\n",
    "    _p = Path(WORK_DIR) / _pat\n",
    "    if _p.exists():\n",
    "        ts_file = _p\n",
    "        break\n",
    "print(f'Time-series file: {ts_file.name}')\n",
    "\n",
    "with h5py.File(ts_file, 'r') as f:\n",
    "    ts_data  = f['timeseries'][:]\n",
    "    ts_dates = [d.decode() for d in f['date'][:]]\n",
    "    atr      = dict(f.attrs)\n",
    "\n",
    "ts_data_mm = ts_data * 1000.0\n",
    "n_dates, nrows, ncols = ts_data_mm.shape\n",
    "print(f'Time-series shape: {ts_data_mm.shape}  ({n_dates} dates)')\n",
    "print(f'Date range: {ts_dates[0]} -> {ts_dates[-1]}')\n",
    "\n",
    "# ── Load velocity ─────────────────────────────────────────────────────────────\n",
    "vel_file = Path(WORK_DIR) / 'velocity.h5'\n",
    "with h5py.File(vel_file, 'r') as f:\n",
    "    vel_data = f['velocity'][:] * 1000.0   # m/yr -> mm/yr\n",
    "    vel_atr  = dict(f.attrs)\n",
    "print(f'Velocity file: {vel_file.name}')\n",
    "\n",
    "# ── Load temporal coherence ───────────────────────────────────────────────────\n",
    "tcoh_file = Path(WORK_DIR) / 'temporalCoherence.h5'\n",
    "if tcoh_file.exists():\n",
    "    with h5py.File(tcoh_file, 'r') as f:\n",
    "        tcoh_data = f['temporalCoherence'][:]\n",
    "    print(f'Temporal coherence file: {tcoh_file.name}')\n",
    "else:\n",
    "    tcoh_data = None\n",
    "    print('temporalCoherence.h5 not found.')\n",
    "\n",
    "# ── Build WGS84 coordinate arrays (handles UTM and geographic CRS) ────────────\n",
    "from pyproj import Transformer as _Tr\n",
    "\n",
    "x0 = float(atr.get('X_FIRST', 0));  dx = float(atr.get('X_STEP',  0.0001))\n",
    "y0 = float(atr.get('Y_FIRST', 0));  dy = float(atr.get('Y_STEP', -0.0001))\n",
    "xs = x0 + dx * np.arange(ncols)\n",
    "ys = y0 + dy * np.arange(nrows)\n",
    "\n",
    "if abs(x0) > 1000:   # projected (UTM metres)\n",
    "    _epsg = int(atr.get('EPSG', 32631))\n",
    "    print(f'UTM detected (EPSG:{_epsg}). Reprojecting to WGS84...')\n",
    "    _t  = _Tr.from_crs(_epsg, 4326, always_xy=True)\n",
    "    _XX, _YY = np.meshgrid(xs, ys)\n",
    "    _LN, _LT = _t.transform(_XX.ravel(), _YY.ravel())\n",
    "    LAT_GRID = _LT.reshape(nrows, ncols)\n",
    "    LON_GRID = _LN.reshape(nrows, ncols)\n",
    "    LATS = LAT_GRID[:, 0]\n",
    "    LONS = LON_GRID[0, :]\n",
    "else:                # geographic (degrees)\n",
    "    LATS = ys;  LONS = xs\n",
    "    LON_GRID, LAT_GRID = np.meshgrid(LONS, LATS)\n",
    "\n",
    "print(f'Lat range: {LATS.min():.4f} to {LATS.max():.4f}')\n",
    "print(f'Lon range: {LONS.min():.4f} to {LONS.max():.4f}')\n",
    "\n",
    "# ── Build coherence mask ──────────────────────────────────────────────────────\n",
    "if tcoh_data is not None:\n",
    "    COH_MASK = tcoh_data >= COH_THRESHOLD\n",
    "else:\n",
    "    COH_MASK = np.ones((nrows, ncols), dtype=bool)\n",
    "\n",
    "# Also mask zero-value pixels (MintPy nodata = 0)\n",
    "COH_MASK = COH_MASK & (vel_data != 0)\n",
    "\n",
    "# Apply AOI mask if provided\n",
    "if AOI_GDF is not None:\n",
    "    from rasterio.transform import from_bounds\n",
    "    from rasterio.features import geometry_mask\n",
    "    _tf = from_bounds(LONS.min(), LATS.min(), LONS.max(), LATS.max(), ncols, nrows)\n",
    "    _aoi = ~geometry_mask([mapping(g) for g in AOI_GDF.geometry],\n",
    "                          transform=_tf, invert=False, out_shape=(nrows, ncols))\n",
    "    if _aoi.sum() == 0:\n",
    "        print('WARNING: AOI has no overlap with data - skipping AOI mask.')\n",
    "    else:\n",
    "        COH_MASK = COH_MASK & _aoi\n",
    "        print(f'AOI mask applied: {_aoi.sum():,} pixels in AOI.')\n",
    "\n",
    "print(f'Valid pixels: {COH_MASK.sum():,} / {nrows*ncols:,} ({100*COH_MASK.mean():.1f}%)')\n",
    "\n",
    "# Quick sanity check on velocity\n",
    "_v = vel_data[COH_MASK]\n",
    "if len(_v):\n",
    "    print(f'Velocity range: {_v.min():.1f} to {_v.max():.1f} mm/yr  |  mean: {_v.mean():.2f} mm/yr')"
    "\n",
    "# ── Build coordinate arrays (UTM-aware) ──────────────────────────────────────\n",
    "from pyproj import Transformer as _Transformer\n",
    "\n",
    "def get_lat_lon(atr, nrows, ncols):\n",
    "    x0 = float(atr.get('X_FIRST', 0))\n",
    "    y0 = float(atr.get('Y_FIRST', 0))\n",
    "    dx = float(atr.get('X_STEP',  0.0001))\n",
    "    dy = float(atr.get('Y_STEP', -0.0001))\n",
    "    xs = x0 + dx * np.arange(ncols)\n",
    "    ys = y0 + dy * np.arange(nrows)\n",
    "    # Detect projected (UTM) coordinates\n",
    "    if abs(x0) > 1000 or abs(y0) > 10000:\n",
    "        epsg_val = atr.get('EPSG', None)\n",
    "        if epsg_val:\n",
    "            epsg = int(epsg_val)\n",
    "        else:\n",
    "            utm_zone = str(atr.get('UTM_ZONE', '31N'))\n",
    "            zone_num = int(''.join(filter(str.isdigit, utm_zone)))\n",
    "            epsg = 32700 + zone_num if utm_zone.upper().endswith('S') else 32600 + zone_num\n",
    "        print(f'UTM detected. Reprojecting EPSG:{epsg} -> WGS84...')\n",
    "        t = _Transformer.from_crs(epsg, 4326, always_xy=True)\n",
    "        XX, YY = np.meshgrid(xs, ys)\n",
    "        LN, LT = t.transform(XX.ravel(), YY.ravel())\n",
    "        LAT_G = LT.reshape(nrows, ncols)\n",
    "        LON_G = LN.reshape(nrows, ncols)\n",
    "        return LAT_G[:, 0], LON_G[0, :], LAT_G, LON_G\n",
    "    else:\n",
    "        LON_G, LAT_G = np.meshgrid(xs, ys)\n",
    "        return ys, xs, LAT_G, LON_G\n",
    "\n",
    "LATS, LONS, LAT_GRID, LON_GRID = get_lat_lon(atr, nrows, ncols)\n",
    "print(f'Lat range: {LATS.min():.4f} to {LATS.max():.4f}')\n",
    "print(f'Lon range: {LONS.min():.4f} to {LONS.max():.4f}')\n",
    "\n",
    "# ── Apply coherence mask ───────────────────────────────────────────────────────\n",
    "if tcoh_data is not None:\n",
    "    COH_MASK = tcoh_data >= COH_THRESHOLD\n",
    "else:\n",
    "    COH_MASK = np.ones((nrows, ncols), dtype=bool)\n",
    "\n",
    "# Apply AOI mask if provided\n",
    "if AOI_GDF is not None:\n",
    "    from rasterio.transform import from_bounds\n",
    "    from rasterio.features import geometry_mask\n",
    "    lat_min, lat_max = float(LATS.min()), float(LATS.max())\n",
    "    lon_min, lon_max = float(LONS.min()), float(LONS.max())\n",
    "    transform = from_bounds(lon_min, lat_min, lon_max, lat_max, ncols, nrows)\n",
    "    aoi_mask = ~geometry_mask(\n",
    "        [mapping(g) for g in AOI_GDF.geometry],\n",
    "        transform=transform, invert=False, out_shape=(nrows, ncols)\n",
    "    )\n",
    "    if aoi_mask.sum() == 0:\n",
    "        print('WARNING: AOI has no overlap with data extent - skipping AOI mask.')\n",
    "        print(f'  Data: lat {lat_min:.4f}-{lat_max:.4f}, lon {lon_min:.4f}-{lon_max:.4f}')\n",
    "    else:\n",
    "        COH_MASK = COH_MASK & aoi_mask\n",
    "        print(f'AOI mask applied: {aoi_mask.sum():,} pixels in AOI.')\n",
    "\n",
    "print(f'Valid pixels: {COH_MASK.sum():,} / {nrows*ncols:,} ({100*COH_MASK.mean():.1f}%)')"
   ]
