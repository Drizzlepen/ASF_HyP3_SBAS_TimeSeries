    "## 16. Export Results as GeoTIFF\n",
    "\n",
    "Writes velocity, cumulative displacement, and coherence as georeferenced GeoTIFFs for use in GIS software (QGIS, ArcGIS, etc.)."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 17,
   "id": "7fe27028",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Saved GeoTIFF: C:\\Users\\USER\\Downloads\\sbas_workspace\\Kiro Job\\velocity_mm_per_yr.tif\n",
      "Saved GeoTIFF: C:\\Users\\USER\\Downloads\\sbas_workspace\\Kiro Job\\cumulative_displacement_mm.tif\n",
      "Saved GeoTIFF: C:\\Users\\USER\\Downloads\\sbas_workspace\\Kiro Job\\temporal_coherence.tif\n",
      "Saved time-series GeoTIFF: C:\\Users\\USER\\Downloads\\sbas_workspace\\Kiro Job\\timeseries_mm.tif\n"
     ]
    }
   ],
   "source": [
    "def save_geotiff(array, filename, lats, lons, nodata=-9999.0):\n",
    "    \"\"\"Save a 2D numpy array as a GeoTIFF in EPSG:4326.\"\"\"\n",
    "    from rasterio.transform import from_bounds\n",
    "    nrows_a, ncols_a = array.shape\n",
    "    transform = from_bounds(\n",
    "        lons.min(), lats.min(), lons.max(), lats.max(), ncols_a, nrows_a\n",
    "    )\n",
    "    out_arr = array.copy().astype(np.float32)\n",
    "    out_arr[np.isnan(out_arr)] = nodata\n",
    "    out_path = WORK_DIR / filename\n",
    "    with rasterio.open(\n",
    "        out_path, 'w', driver='GTiff',\n",
    "        height=nrows_a, width=ncols_a, count=1,\n",
    "        dtype='float32', crs='EPSG:4326',\n",
    "        transform=transform, nodata=nodata\n",
    "    ) as dst:\n",
    "        dst.write(out_arr, 1)\n",
    "    print(f'Saved GeoTIFF: {out_path}')\n",
    "\n",
    "# Velocity\n",
    "vel_export = vel_data.copy().astype(float)\n",
    "vel_export[~COH_MASK] = np.nan\n",
    "save_geotiff(vel_export, 'velocity_mm_per_yr.tif', LATS, LONS)\n",
    "\n",
    "# Cumulative displacement\n",
    "cum_export = cumulative.copy().astype(float)\n",
    "cum_export[~COH_MASK] = np.nan\n",
    "save_geotiff(cum_export, 'cumulative_displacement_mm.tif', LATS, LONS)\n",
    "\n",
    "# Temporal coherence\n",
    "if tcoh_data is not None:\n",
    "    save_geotiff(tcoh_data.astype(float), 'temporal_coherence.tif', LATS, LONS)\n",
    "\n",
    "# Time-series stack (each date as a band)\n",
    "from rasterio.transform import from_bounds\n",
    "ts_path = WORK_DIR / 'timeseries_mm.tif'\n",
    "transform = from_bounds(LONS.min(), LATS.min(), LONS.max(), LATS.max(), ncols, nrows)\n",
    "with rasterio.open(\n",
    "    ts_path, 'w', driver='GTiff',\n",
    "    height=nrows, width=ncols, count=n_dates,\n",
    "    dtype='float32', crs='EPSG:4326',\n",
    "    transform=transform, nodata=-9999.0\n",
    ") as dst:\n",
    "    for i in range(n_dates):\n",
    "        band = ts_data_mm[i].copy().astype(np.float32)\n",
    "        band[~COH_MASK] = -9999.0\n",
    "        dst.write(band, i + 1)\n",
    "        dst.update_tags(i + 1, date=ts_dates[i])\n",
    "print(f'Saved time-series GeoTIFF: {ts_path}')"
   ]
  },
